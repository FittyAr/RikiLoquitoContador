@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject IConfigService ConfigService
@inject IFileScannerService FileScanner
@inject IAiService AiService
@inject IExportService ExportService
@inject II18nService Localizer
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <!-- Conflict Alerts Banner -->
    @if (_facturas.Any(f => f.Status == "Conflict"))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6 rounded-lg" Style="background: linear-gradient(135deg, #b71c1c 0%, #d32f2f 100%); border: 1px solid rgba(255, 255, 255, 0.1); color: white;">
            <div class="d-flex flex-column gap-2">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                    <span style="font-weight: 700;">@Localizer.T("Dashboard.ConflictBanner.Title")</span>
                </div>
                <div class="mt-2" style="max-height: 150px; overflow-y: auto; background: rgba(0, 0, 0, 0.2); padding: 8px; border-radius: 4px; font-size: 0.85rem;">
                    @foreach (var conflict in _facturas.Where(f => f.Status == "Conflict"))
                    {
                        <div class="py-1 d-flex justify-space-between align-center border-bottom border-secondary">
                            <div>
                                <strong style="color: #FFCDD2;">@conflict.FileName</strong>: 
                                <span style="font-style: italic;">@conflict.ErrorMessage</span>
                            </div>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Inherit" OnClick="@(() => ProcessInvoiceWithAiAsync(conflict))" Style="text-transform: none; text-decoration: underline;">
                                Reintentar
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
        </MudAlert>
    }

    <!-- Header Summary Cards -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Total Facturas</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_facturas.Count</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #0D47A1 0%, #1565C0 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Monto Total</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">$ @_facturas.Sum(f => f.TotalAmount ?? 0).ToString("N2")</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #E65100 0%, #EF6C00 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Clientes</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_facturas.Select(f => f.ClientName).Distinct().Count(c => !string.IsNullOrEmpty(c))</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #004D40 0%, #00695C 100%); color: white;">
                <MudIcon Icon="@(FileScanner.IsMonitoring ? Icons.Material.Filled.Wifi : Icons.Material.Filled.WifiOff)" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Monitoreo</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @(FileScanner.IsMonitoring ? Localizer.T("Dashboard.ScannerStatus.Monitoring") : Localizer.T("Dashboard.ScannerStatus.NotMonitoring"))
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Main Content Table & Filters -->
    <MudPaper Elevation="8" Class="pa-6 rounded-lg mb-6" Style="background: rgba(33, 33, 33, 0.85); color: white; border: 1px solid rgba(255, 255, 255, 0.1);">
        <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-4 mb-6">
            <div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #C2FE71;">
                    @Localizer.T("Dashboard.Title")
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Monitoreando: @ConfigService.GetSettings().ScanningSettings.WatchFolderPath
                </MudText>
            </div>
            
            <div class="d-flex flex-wrap gap-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="TriggerScan"
                           Disabled="_isScanning"
                           Style="background: linear-gradient(135deg, #00796B 0%, #009688 100%); color: white; font-weight: 600;"
                           Class="rounded-pill">
                    @if (_isScanning)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @Localizer.T("Dashboard.Scanning")
                    }
                    else
                    {
                        @Localizer.T("Dashboard.ScanButton")
                    }
                </MudButton>

                <MudMenu Label="Exportar Datos" 
                         Icon="@Icons.Material.Filled.Download" 
                         Variant="Variant.Filled" 
                         Color="Color.Info"
                         Style="background: linear-gradient(135deg, #1565C0 0%, #1E88E5 100%); color: white;"
                         Class="rounded-pill">
                    <MudMenuItem OnClick="ExportCsv" Icon="@Icons.Material.Filled.TableChart">CSV</MudMenuItem>
                    <MudMenuItem OnClick="ExportJson" Icon="@Icons.Material.Filled.Code">JSON</MudMenuItem>
                    <MudMenuItem OnClick="ExportExcel" Icon="@Icons.Material.Filled.GridOn">Sincronizar Excel (.xlsx)</MudMenuItem>
                </MudMenu>
            </div>
        </div>

        <!-- Table Filters -->
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_searchQuery"
                              Placeholder="@Localizer.T("Dashboard.SearchPlaceholder")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="color: white;"
                              Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string"
                           Label="@Localizer.T("Dashboard.FilterClient")"
                           @bind-Value="_selectedClient"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="color: white;">
                    <MudSelectItem Value="@("")">Todos los clientes</MudSelectItem>
                    @foreach (var client in _clients)
                    {
                        <MudSelectItem Value="@client">@client</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <!-- Invoices Table -->
        <MudTable Items="FilteredFacturas"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Loading="_isLoading"
                  Dense="true"
                  Class="rounded-lg"
                  Style="background: rgba(43, 43, 43, 0.5); color: white;">
            <HeaderContent>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.FileName")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Client")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Amount")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Size")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Date")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Indexed")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600; text-align: center;">@Localizer.T("Dashboard.Table.Actions")</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Archivo" Style="font-weight: 500;">
                    <div class="d-flex align-center">
                        <MudIconButton Icon="@(_expandedInvoiceIds.Contains(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                       Color="Color.Default" 
                                       Size="Size.Small" 
                                       OnClick="@(() => ToggleExpand(context.Id))" 
                                       Class="mr-1" />
                        <MudIcon Icon="@GetFileIcon(context.FileExtension)" Class="mr-2" Color="@GetFileIconColor(context.FileExtension)" />
                        <span title="@context.FilePath">@context.FileName</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Cliente">
                    <MudTooltip Text="@(string.IsNullOrEmpty(context.Comments) ? "Sin comentarios" : context.Comments)">
                        <MudChip T="string" 
                                 Color="@(context.ClientName == "Fallo IA" ? Color.Error : Color.Success)" 
                                 Variant="Variant.Text" 
                                 Size="Size.Small">
                            @(context.ClientName ?? "Sin asignar")
                        </MudChip>
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Monto">
                    @if (context.TotalAmount.HasValue)
                    {
                        <span style="font-weight: 600; color: #81C784;">$ @context.TotalAmount.Value.ToString("N2")</span>
                    }
                    else
                    {
                        <span class="mud-text-secondary italic">-</span>
                    }
                </MudTd>
                <MudTd DataLabel="Tamaño">@GetFormattedSize(context.FileSizeBytes)</MudTd>
                <MudTd DataLabel="Creación">@context.FileCreatedAt.ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Indexado">@context.IndexedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Acciones" Style="text-align: center;">
                    <div class="d-flex justify-center gap-1">
                        <MudTooltip Text="Editar manualmente">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                           Color="Color.Success" 
                                           Size="Size.Small" 
                                           OnClick="@(() => OpenEditDialog(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Procesar con IA">
                            @if (_processingAiIds.Contains(context.Id))
                            {
                                <MudProgressCircular Color="Color.Info" Size="Size.Small" Indeterminate="true" Class="ma-1" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Psychology" 
                                               Color="Color.Info" 
                                               Size="Size.Small" 
                                               OnClick="@(() => ProcessInvoiceWithAiAsync(context))" />
                            }
                        </MudTooltip>
                        <MudTooltip Text="Eliminar factura">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                           Color="Color.Error" 
                                           Size="Size.Small" 
                                           OnClick="@(() => OpenDeleteDialog(context))" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (_expandedInvoiceIds.Contains(context.Id))
                {
                    <MudTr>
                        <td colspan="7" style="padding: 16px; background: rgba(30, 30, 30, 0.4);">
                            <div class="pa-4 rounded-lg" style="background: rgba(40, 40, 40, 0.7); border: 1px solid rgba(255, 255, 255, 0.05); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5); backdrop-filter: blur(5px);">
                                <MudGrid Class="mb-4">
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle1" Style="color: #C2FE71; font-weight: 700;" Class="mb-3">
                                            Datos del Comprobante (Receptor)
                                        </MudText>
                                        <div class="d-flex flex-column gap-2">
                                            <div>
                                                <span class="mud-text-secondary">CUIT: </span>
                                                <span style="font-weight: 600;">@(context.ClientCuit ?? "-")</span>
                                            </div>
                                            <div>
                                                <span class="mud-text-secondary">Condición IVA: </span>
                                                <span style="font-weight: 600;">@(context.ClientVatType ?? "-")</span>
                                            </div>
                                            <div>
                                                <span class="mud-text-secondary">Tipo Factura: </span>
                                                <span style="font-weight: 600;">@(context.InvoiceType ?? "-")</span>
                                            </div>
                                            <div>
                                                <span class="mud-text-secondary">Punto de Venta / Nro: </span>
                                                <span style="font-weight: 600;">
                                                    @(!string.IsNullOrEmpty(context.PointOfSale) || !string.IsNullOrEmpty(context.InvoiceNumber) 
                                                        ? $"{context.PointOfSale}-{context.InvoiceNumber}" 
                                                        : "-")
                                                </span>
                                            </div>
                                            <div>
                                                <span class="mud-text-secondary">Fecha Emisión: </span>
                                                <span style="font-weight: 600;">@(context.IssueDate?.ToString("dd/MM/yyyy") ?? "-")</span>
                                            </div>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle1" Style="color: #C2FE71; font-weight: 700;" Class="mb-3">
                                            Estado del Proceso
                                        </MudText>
                                        <div class="d-flex flex-column gap-2">
                                            <div>
                                                <span class="mud-text-secondary">Estado: </span>
                                                <MudChip T="string" 
                                                         Color="@(context.Status == "Success" ? Color.Success : Color.Error)" 
                                                         Size="Size.Small" 
                                                         Variant="Variant.Filled">
                                                    @(context.Status)
                                                </MudChip>
                                            </div>
                                            @if (!string.IsNullOrEmpty(context.ErrorMessage))
                                            {
                                                <div class="mt-2 pa-3 rounded" style="background: rgba(244, 67, 54, 0.1); border: 1px solid rgba(244, 67, 54, 0.3); color: #FF8A80;">
                                                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" Class="mr-2" />
                                                    <strong>Error:</strong> @context.ErrorMessage
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(context.ProcessedPath))
                                            {
                                                <div class="mt-1">
                                                    <span class="mud-text-secondary">Ruta Procesada: </span>
                                                    <span style="font-size: 0.85rem; font-family: monospace; word-break: break-all;">@context.ProcessedPath</span>
                                                </div>
                                            }
                                        </div>
                                    </MudItem>
                                </MudGrid>

                                <MudText Typo="Typo.subtitle1" Style="color: #C2FE71; font-weight: 700;" Class="mb-2">
                                    @Localizer.T("Dashboard.Detail.ItemsTitle")
                                </MudText>
                                
                                @if (context.Detalles != null && context.Detalles.Any())
                                {
                                    <MudTable Items="context.Detalles" 
                                              Dense="true" 
                                              Hover="true" 
                                              Style="background: rgba(20, 20, 20, 0.5); color: white;"
                                              Elevation="0">
                                        <HeaderContent>
                                            <MudTh Style="color: #81C784; font-weight: 600;">@Localizer.T("Dashboard.Detail.Description")</MudTh>
                                            <MudTh Style="color: #81C784; font-weight: 600; text-align: right;">@Localizer.T("Dashboard.Detail.Quantity")</MudTh>
                                            <MudTh Style="color: #81C784; font-weight: 600; text-align: right;">@Localizer.T("Dashboard.Detail.UnitPrice")</MudTh>
                                            <MudTh Style="color: #81C784; font-weight: 600; text-align: right;">@Localizer.T("Dashboard.Detail.VatRate")</MudTh>
                                            <MudTh Style="color: #81C784; font-weight: 600; text-align: right;">@Localizer.T("Dashboard.Detail.Subtotal")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="detail">
                                            <MudTd DataLabel="Descripción">@detail.Description</MudTd>
                                            <MudTd DataLabel="Cantidad" Style="text-align: right;">@detail.Quantity.ToString("N2")</MudTd>
                                            <MudTd DataLabel="Precio Unitario" Style="text-align: right;">$ @detail.UnitPrice.ToString("N2")</MudTd>
                                            <MudTd DataLabel="Tasa IVA" Style="text-align: right;">@(detail.VatRate.HasValue ? $"{detail.VatRate.Value}%" : "-")</MudTd>
                                            <MudTd DataLabel="Subtotal" Style="text-align: right; font-weight: 600;">$ @detail.Subtotal.ToString("N2")</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                    
                                    <div class="d-flex justify-end mt-3 pa-2 rounded" style="background: rgba(255, 255, 255, 0.03);">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #81C784;">
                                            Total: $ @(context.TotalAmount.HasValue ? context.TotalAmount.Value.ToString("N2") : context.Detalles.Sum(d => d.Subtotal).ToString("N2"))
                                        </MudText>
                                    </div>
                                }
                                else
                                {
                                    <div class="pa-3 text-center rounded" style="background: rgba(255, 255, 255, 0.02);">
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary italic">No hay renglones detallados para esta factura.</MudText>
                                    </div>
                                }
                            </div>
                        </td>
                    </MudTr>
                }
            </ChildRowContent>
            <NoRecordsContent>
                <div class="pa-4 text-center">
                    <MudText Class="mud-text-secondary">@Localizer.T("Dashboard.Table.NoRecords")</MudText>
                </div>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" RowsPerPageString="Filas por página:" />
            </PagerContent>
        </MudTable>
    </MudPaper>

    <!-- Inline Edit Dialog (using MudDialog inside page state) -->
    <MudDialog @bind-Visible="_editDialogVisible" Options="_dialogOptions">
        <TitleContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Success" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">
                    @Localizer.T("Dashboard.EditDialog.Title")
                </MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <div style="background: #212121; color: white;" class="d-flex flex-column gap-4 pa-4 rounded">
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Archivo: @_editingFactura?.FileName</MudText>
                
                <MudTextField T="string"
                              Label="@Localizer.T("Dashboard.EditDialog.ClientLabel")"
                              @bind-Value="_editClientName"
                              Variant="Variant.Outlined"
                              Style="color: white;" />

                <MudNumericField T="decimal?"
                                 Label="@Localizer.T("Dashboard.EditDialog.AmountLabel")"
                                 @bind-Value="_editTotalAmount"
                                 Variant="Variant.Outlined"
                                 Style="color: white;"
                                 Min="0" />

                <MudTextField T="string"
                              Label="@Localizer.T("Dashboard.EditDialog.CommentsLabel")"
                              @bind-Value="_editComments"
                              Variant="Variant.Outlined"
                              Style="color: white;"
                              Lines="3" />
            </div>
        </DialogContent>
        <DialogActions>
            <div class="pa-4 d-flex justify-end gap-3" style="background: #212121; width: 100%;">
                <MudButton Variant="Variant.Text" 
                           Color="Color.Default" 
                           OnClick="CloseEditDialog">
                    @Localizer.T("Dashboard.EditDialog.Cancel")
                </MudButton>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Success" 
                           OnClick="SaveInvoiceChanges"
                           Style="background: linear-gradient(135deg, #049F6C 0%, #87D37C 100%); color: white; font-weight: 600;"
                           Class="px-4 py-2 rounded-pill">
                    @Localizer.T("Dashboard.EditDialog.Save")
                </MudButton>
            </div>
        </DialogActions>
    </MudDialog>

    <!-- Delete Confirmation Dialog -->
    <MudDialog @bind-Visible="_deleteDialogVisible" Options="_dialogOptions">
        <TitleContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">
                    @Localizer.T("Dashboard.DeleteDialog.Title")
                </MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <div style="background: #212121; color: white;" class="d-flex flex-column gap-4 pa-4 rounded">
                <MudText Typo="Typo.body1">
                    @if (!string.IsNullOrWhiteSpace(_deletingFactura?.InvoiceNumber))
                    {
                        @string.Format(Localizer.T("Dashboard.DeleteDialog.Message"), _deletingFactura?.FileName, _deletingFactura?.InvoiceNumber)
                    }
                    else
                    {
                        @string.Format(Localizer.T("Dashboard.DeleteDialog.MessageFallback"), _deletingFactura?.FileName, "ELIMINAR")
                    }
                </MudText>
                
                <MudTextField T="string"
                              Label="@Localizer.T("Dashboard.DeleteDialog.Placeholder")"
                              @bind-Value="_deleteConfirmInput"
                              Variant="Variant.Outlined"
                              Style="color: white;"
                              Immediate="true" />
            </div>
        </DialogContent>
        <DialogActions>
            <div class="pa-4 d-flex justify-end gap-3" style="background: #212121; width: 100%;">
                <MudButton Variant="Variant.Text" 
                           Color="Color.Default" 
                           OnClick="CloseDeleteDialog">
                    @Localizer.T("Dashboard.DeleteDialog.Cancel")
                </MudButton>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Error" 
                           OnClick="ConfirmDeleteInvoiceAsync"
                           Disabled="@(_deleteConfirmInput != _expectedDeleteConfirmValue)"
                           Style="font-weight: 600;"
                           Class="px-4 py-2 rounded-pill">
                    @Localizer.T("Dashboard.DeleteDialog.Confirm")
                </MudButton>
            </div>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private List<Factura> _facturas = new();
    private List<string> _clients = new();
    private bool _isLoading = true;
    private bool _isScanning = false;
    private readonly HashSet<int> _processingAiIds = new();
    
    // Expanded row state
    private readonly HashSet<int> _expandedInvoiceIds = new();

    // Filters
    private string _searchQuery = string.Empty;
    private string _selectedClient = string.Empty;

    // Edit Modal State
    private bool _editDialogVisible;
    private Factura? _editingFactura;
    private string _editClientName = string.Empty;
    private decimal? _editTotalAmount;
    private string _editComments = string.Empty;

    // Delete Modal State
    private bool _deleteDialogVisible;
    private Factura? _deletingFactura;
    private string _deleteConfirmInput = string.Empty;
    private string _expectedDeleteConfirmValue = string.Empty;
    
    private readonly DialogOptions _dialogOptions = new() 
    { 
        CloseOnEscapeKey = true, 
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    private IEnumerable<Factura> FilteredFacturas => _facturas
        .Where(f => 
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            return f.FileName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                   (f.ClientName?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false);
        })
        .Where(f => 
        {
            if (string.IsNullOrEmpty(_selectedClient)) return true;
            return f.ClientName == _selectedClient;
        })
        .OrderByDescending(f => f.IndexedAt);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        
        // Start watching for changes
        FileScanner.OnFileDetected += HandleFileDetected;
        FileScanner.StartMonitoring();

        // Register JS download script if not registered
        await JS.InvokeVoidAsync("eval", @"
            window.downloadFileFromBytes = (fileName, contentType, bytesBase64) => {
                const link = document.createElement('a');
                link.download = fileName;
                link.href = 'data:' + contentType + ';base64,' + bytesBase64;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            };
        ");
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            using var context = await DbContextFactory.CreateDbContextAsync();
            _facturas = await context.Facturas.Include(f => f.Detalles).ToListAsync();
            
            _clients = _facturas
                .Select(f => f.ClientName)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList()!;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando datos: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

