    {
        _deletingFactura = factura;
        _deleteConfirmInput = string.Empty;
        _expectedDeleteConfirmValue = !string.IsNullOrWhiteSpace(factura.InvoiceNumber) 
            ? factura.InvoiceNumber 
            : "ELIMINAR";
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _deletingFactura = null;
        _deleteConfirmInput = string.Empty;
    }

    private async Task ConfirmDeleteInvoiceAsync()
    {
        if (_deletingFactura == null) return;

        try
        {
            if (!string.IsNullOrWhiteSpace(_deletingFactura.FilePath) && File.Exists(_deletingFactura.FilePath))
            {
                try
                {
                    File.Delete(_deletingFactura.FilePath);
                }
                catch (Exception fileEx)
                {
                    Console.WriteLine($"[Delete] Could not delete physical file at {_deletingFactura.FilePath}: {fileEx.Message}");
                }
            }

            using var context = await DbContextFactory.CreateDbContextAsync();
            var dbFactura = await context.Facturas.FindAsync(_deletingFactura.Id);
            if (dbFactura != null)
            {
                context.Facturas.Remove(dbFactura);
                await context.SaveChangesAsync();
                
                Snackbar.Add(Localizer.T("Dashboard.DeleteDialog.Success"), Severity.Success);
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar la factura: {ex.Message}", Severity.Error);
        }
        finally
        {
            CloseDeleteDialog();
        }
    }

