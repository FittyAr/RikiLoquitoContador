@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject IConfigService ConfigService
@inject IFileScannerService FileScanner
@inject IExportService ExportService
@inject II18nService Localizer
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <!-- Header Summary Cards -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Total Facturas</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_facturas.Count</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #0D47A1 0%, #1565C0 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Monto Total</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">$ @_facturas.Sum(f => f.TotalAmount ?? 0).ToString("N2")</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #E65100 0%, #EF6C00 100%); color: white;">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Clientes</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_facturas.Select(f => f.ClientName).Distinct().Count(c => !string.IsNullOrEmpty(c))</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="d-flex align-center pa-4 rounded-lg" Elevation="6" Style="background: linear-gradient(135deg, #004D40 0%, #00695C 100%); color: white;">
                <MudIcon Icon="@(FileScanner.IsMonitoring ? Icons.Material.Filled.Wifi : Icons.Material.Filled.WifiOff)" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.subtitle2">Monitoreo</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @(FileScanner.IsMonitoring ? Localizer.T("Dashboard.ScannerStatus.Monitoring") : Localizer.T("Dashboard.ScannerStatus.NotMonitoring"))
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Main Content Table & Filters -->
    <MudPaper Elevation="8" Class="pa-6 rounded-lg mb-6" Style="background: rgba(33, 33, 33, 0.85); color: white; border: 1px solid rgba(255, 255, 255, 0.1);">
        <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-4 mb-6">
            <div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #C2FE71;">
                    @Localizer.T("Dashboard.Title")
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Monitoreando: @ConfigService.GetSettings().ScanningSettings.WatchFolderPath
                </MudText>
            </div>
            
            <div class="d-flex flex-wrap gap-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="TriggerScan"
                           Disabled="_isScanning"
                           Style="background: linear-gradient(135deg, #00796B 0%, #009688 100%); color: white; font-weight: 600;"
                           Class="rounded-pill">
                    @if (_isScanning)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @Localizer.T("Dashboard.Scanning")
                    }
                    else
                    {
                        @Localizer.T("Dashboard.ScanButton")
                    }
                </MudButton>

                <MudMenu Label="Exportar Datos" 
                         Icon="@Icons.Material.Filled.Download" 
                         Variant="Variant.Filled" 
                         Color="Color.Info"
                         Style="background: linear-gradient(135deg, #1565C0 0%, #1E88E5 100%); color: white;"
                         Class="rounded-pill">
                    <MudMenuItem OnClick="ExportCsv" Icon="@Icons.Material.Filled.TableChart">CSV</MudMenuItem>
                    <MudMenuItem OnClick="ExportJson" Icon="@Icons.Material.Filled.Code">JSON</MudMenuItem>
                    <MudMenuItem OnClick="ExportExcel" Icon="@Icons.Material.Filled.GridOn">Sincronizar Excel (.xlsx)</MudMenuItem>
                </MudMenu>
            </div>
        </div>

        <!-- Table Filters -->
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_searchQuery"
                              Placeholder="@Localizer.T("Dashboard.SearchPlaceholder")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="color: white;"
                              Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string"
                           Label="@Localizer.T("Dashboard.FilterClient")"
                           @bind-Value="_selectedClient"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="color: white;">
                    <MudSelectItem Value="@("")">Todos los clientes</MudSelectItem>
                    @foreach (var client in _clients)
                    {
                        <MudSelectItem Value="@client">@client</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <!-- Invoices Table -->
        <MudTable Items="FilteredFacturas"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Loading="_isLoading"
                  Dense="true"
                  Class="rounded-lg"
                  Style="background: rgba(43, 43, 43, 0.5); color: white;">
            <HeaderContent>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.FileName")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Client")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Amount")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Size")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Date")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600;">@Localizer.T("Dashboard.Table.Indexed")</MudTh>
                <MudTh Style="color: #C2FE71; font-weight: 600; text-align: center;">@Localizer.T("Dashboard.Table.Actions")</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Archivo" Style="font-weight: 500;">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@GetFileIcon(context.FileExtension)" Class="mr-2" Color="@GetFileIconColor(context.FileExtension)" />
                        <span title="@context.FilePath">@context.FileName</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Cliente">
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small">
                        @(context.ClientName ?? "Sin asignar")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Monto">
                    @if (context.TotalAmount.HasValue)
                    {
                        <span style="font-weight: 600; color: #81C784;">$ @context.TotalAmount.Value.ToString("N2")</span>
                    }
                    else
                    {
                        <span class="mud-text-secondary italic">-</span>
                    }
                </MudTd>
                <MudTd DataLabel="Tamaño">@GetFormattedSize(context.FileSizeBytes)</MudTd>
                <MudTd DataLabel="Creación">@context.FileCreatedAt.ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Indexado">@context.IndexedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Acciones" Style="text-align: center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Color="Color.Success" 
                                   Size="Size.Small" 
                                   OnClick="@(() => OpenEditDialog(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="pa-4 text-center">
                    <MudText Class="mud-text-secondary">@Localizer.T("Dashboard.Table.NoRecords")</MudText>
                </div>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" RowsPerPageString="Filas por página:" />
            </PagerContent>
        </MudTable>
    </MudPaper>

    <!-- Inline Edit Dialog (using MudDialog inside page state) -->
    <MudDialog @bind-Visible="_editDialogVisible" Options="_dialogOptions">
        <TitleContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Success" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">
                    @Localizer.T("Dashboard.EditDialog.Title")
                </MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <div style="background: #212121; color: white;" class="d-flex flex-column gap-4 pa-4 rounded">
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Archivo: @_editingFactura?.FileName</MudText>
                
                <MudTextField T="string"
                              Label="@Localizer.T("Dashboard.EditDialog.ClientLabel")"
                              @bind-Value="_editClientName"
                              Variant="Variant.Outlined"
                              Style="color: white;" />

                <MudNumericField T="decimal?"
                                 Label="@Localizer.T("Dashboard.EditDialog.AmountLabel")"
                                 @bind-Value="_editTotalAmount"
                                 Variant="Variant.Outlined"
                                 Style="color: white;"
                                 Min="0" />

                <MudTextField T="string"
                              Label="@Localizer.T("Dashboard.EditDialog.CommentsLabel")"
                              @bind-Value="_editComments"
                              Variant="Variant.Outlined"
                              Style="color: white;"
                              Lines="3" />
            </div>
        </DialogContent>
        <DialogActions>
            <div class="pa-4 d-flex justify-end gap-3" style="background: #212121; width: 100%;">
                <MudButton Variant="Variant.Text" 
                           Color="Color.Default" 
                           OnClick="CloseEditDialog">
                    @Localizer.T("Dashboard.EditDialog.Cancel")
                </MudButton>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Success" 
                           OnClick="SaveInvoiceChanges"
                           Style="background: linear-gradient(135deg, #049F6C 0%, #87D37C 100%); color: white; font-weight: 600;"
                           Class="px-4 py-2 rounded-pill">
                    @Localizer.T("Dashboard.EditDialog.Save")
                </MudButton>
            </div>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private List<Factura> _facturas = new();
    private List<string> _clients = new();
    private bool _isLoading = true;
    private bool _isScanning = false;
    
    // Filters
    private string _searchQuery = string.Empty;
    private string _selectedClient = string.Empty;

    // Edit Modal State
    private bool _editDialogVisible;
    private Factura? _editingFactura;
    private string _editClientName = string.Empty;
    private decimal? _editTotalAmount;
    private string _editComments = string.Empty;
    
    private readonly DialogOptions _dialogOptions = new() 
    { 
        CloseOnEscapeKey = true, 
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    private IEnumerable<Factura> FilteredFacturas => _facturas
        .Where(f => 
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            return f.FileName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                   (f.ClientName?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false);
        })
        .Where(f => 
        {
            if (string.IsNullOrEmpty(_selectedClient)) return true;
            return f.ClientName == _selectedClient;
        })
        .OrderByDescending(f => f.IndexedAt);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        
        // Start watching for changes
        FileScanner.OnFileDetected += HandleFileDetected;
        FileScanner.StartMonitoring();

        // Register JS download script if not registered
        await JS.InvokeVoidAsync("eval", @"
            window.downloadFileFromBytes = (fileName, contentType, bytesBase64) => {
                const link = document.createElement('a');
                link.download = fileName;
                link.href = 'data:' + contentType + ';base64,' + bytesBase64;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            };
        ");
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            using var context = await DbContextFactory.CreateDbContextAsync();
            _facturas = await context.Facturas.ToListAsync();
            
            _clients = _facturas
                .Select(f => f.ClientName)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList()!;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando datos: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleFileDetected(Factura factura)
    {
        InvokeAsync(async () =>
        {
            await LoadDataAsync();
            Snackbar.Add($"Nueva factura detectada: {factura.FileName}", Severity.Info);
            StateHasChanged();
        });
    }

    private async Task TriggerScan()
    {
        _isScanning = true;
        try
        {
            await FileScanner.ScanFolderAsync();
            await LoadDataAsync();
            Snackbar.Add("Escaneo manual completado.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de escaneo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScanning = false;
        }
    }

    // Modal Action
    private void OpenEditDialog(Factura factura)
    {
        _editingFactura = factura;
        _editClientName = factura.ClientName ?? "";
        _editTotalAmount = factura.TotalAmount;
        _editComments = factura.Comments ?? "";
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
        _editingFactura = null;
    }

    private async Task SaveInvoiceChanges()
    {
        if (_editingFactura == null) return;

        try
        {
            using var context = await DbContextFactory.CreateDbContextAsync();
            var dbFactura = await context.Facturas.FindAsync(_editingFactura.Id);
            if (dbFactura != null)
            {
                dbFactura.ClientName = _editClientName;
                dbFactura.TotalAmount = _editTotalAmount;
                dbFactura.Comments = _editComments;
                
                await context.SaveChangesAsync();
                
                Snackbar.Add(Localizer.T("Dashboard.EditDialog.Success"), Severity.Success);
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al actualizar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _editDialogVisible = false;
            _editingFactura = null;
        }
    }

    // Export Handlers
    private async Task ExportCsv()
    {
        try
        {
            var bytes = ExportService.ExportToCsv(FilteredFacturas);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"Facturas_{DateTime.Now:yyyyMMdd}.csv", "text/csv", base64);
            Snackbar.Add("CSV exportado exitosamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al exportar CSV: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportJson()
    {
        try
        {
            var bytes = ExportService.ExportToJson(FilteredFacturas);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", $"Facturas_{DateTime.Now:yyyyMMdd}.json", "application/json", base64);
            Snackbar.Add("JSON exportado exitosamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al exportar JSON: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportExcel()
    {
        try
        {
            var settings = ConfigService.GetSettings();
            var excelPath = settings.ScanningSettings.ExcelFilePath;

            if (string.IsNullOrWhiteSpace(excelPath))
            {
                var folder = settings.ScanningSettings.WatchFolderPath;
                if (string.IsNullOrWhiteSpace(folder) || !Directory.Exists(folder))
                {
                    Snackbar.Add("Configure una carpeta válida o una ruta de Excel antes de sincronizar.", Severity.Warning);
                    return;
                }
                excelPath = Path.Combine(folder, "FacturasSincronizadas.xlsx");
            }
            else
            {
                var dir = Path.GetDirectoryName(excelPath);
                if (!string.IsNullOrWhiteSpace(dir) && !Directory.Exists(dir))
                {
                    Directory.CreateDirectory(dir);
                }
            }

            await ExportService.ExportToExcelIncrementalAsync(FilteredFacturas, excelPath);
            Snackbar.Add($"Sincronización incremental de Excel completada: {excelPath}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al sincronizar Excel: {ex.Message}", Severity.Error);
        }
    }

    // Helpers
    private string GetFormattedSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{((double)bytes / (1024 * 1024)):F2} MB";
        return $"{((double)bytes / 1024):F2} KB";
    }

    private string GetFileIcon(string extension)
    {
        return extension switch
        {
            ".pdf" => Icons.Material.Filled.PictureAsPdf,
            ".png" or ".jpg" or ".jpeg" => Icons.Material.Filled.Image,
            ".doc" or ".docx" => Icons.Material.Filled.Description,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    private Color GetFileIconColor(string extension)
    {
        return extension switch
        {
            ".pdf" => Color.Error,
            ".png" or ".jpg" or ".jpeg" => Color.Info,
            ".doc" or ".docx" => Color.Primary,
            _ => Color.Default
        };
    }

    public void Dispose()
    {
        FileScanner.OnFileDetected -= HandleFileDetected;
    }
}
