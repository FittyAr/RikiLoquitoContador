    private async Task ProcessInvoiceWithAiAsync(Factura factura)
    {
        if (factura == null) return;
        
        _processingAiIds.Add(factura.Id);
        StateHasChanged();

        try
        {
            var settings = ConfigService.GetSettings();
            if (string.IsNullOrWhiteSpace(settings.AiSettings.ApiKey))
            {
                Snackbar.Add("Configure la API Key de la IA en la pantalla de Ajustes.", Severity.Warning);
                return;
            }

            Snackbar.Add($"Analizando '{factura.FileName}' con IA...", Severity.Info);

            var aiResult = await AiService.AnalyzeInvoiceAsync(factura.FilePath);

            using var context = await DbContextFactory.CreateDbContextAsync();
            var dbFactura = await context.Facturas.Include(f => f.Detalles).FirstOrDefaultAsync(f => f.Id == factura.Id);
            if (dbFactura != null)
            {
                bool hasAiError = aiResult.Comments != null && 
                                 (aiResult.Comments.StartsWith("Error de API") || 
                                  aiResult.Comments.StartsWith("Fallo de conexión") ||
                                  aiResult.Comments.Contains("Error de conexión"));

                dbFactura.ClientName = aiResult.ClientName ?? "Fallo IA";
                dbFactura.TotalAmount = aiResult.TotalAmount;
                dbFactura.Comments = aiResult.Comments;
                dbFactura.InvoiceType = aiResult.InvoiceType;
                dbFactura.PointOfSale = aiResult.PointOfSale;
                dbFactura.InvoiceNumber = aiResult.InvoiceNumber;
                dbFactura.IssueDate = aiResult.IssueDate;
                dbFactura.ClientCuit = aiResult.ClientCuit;
                dbFactura.ClientVatType = aiResult.ClientVatType;
                dbFactura.Status = (hasAiError || string.IsNullOrEmpty(aiResult.ClientName)) ? "Conflict" : "Success";
                dbFactura.ErrorMessage = hasAiError ? aiResult.Comments : null;

                // Remove existing details
                context.FacturaDetalles.RemoveRange(dbFactura.Detalles);
                dbFactura.Detalles.Clear();

                // Add new details
                if (aiResult.Items != null)
                {
                    foreach (var item in aiResult.Items)
                    {
                        dbFactura.Detalles.Add(new FacturaDetalle
                        {
                            Description = item.Description,
                            Quantity = item.Quantity,
                            UnitPrice = item.UnitPrice,
                            Subtotal = item.Subtotal,
                            VatRate = item.VatRate
                        });
                    }
                }

                // If it is now success, we should move the file to the client's folder
                if (dbFactura.Status == "Success" && File.Exists(dbFactura.FilePath))
                {
                    try
                    {
                        var fileInfo = new FileInfo(dbFactura.FilePath);
                        string clientFolder = Path.Combine(settings.ScanningSettings.ProcessedFolderPath, CleanStringForFileName(aiResult.ClientName ?? "SinCliente"));
                        if (!Directory.Exists(clientFolder))
                        {
                            Directory.CreateDirectory(clientFolder);
                        }

                        string logicalName = GetLogicalName(aiResult, fileInfo.Name, fileInfo.Extension);
                        string destinationPath = Path.Combine(clientFolder, logicalName);

                        if (destinationPath != dbFactura.FilePath)
                        {
                            if (File.Exists(destinationPath))
                            {
                                string nameWithoutExt = Path.GetFileNameWithoutExtension(logicalName);
                                destinationPath = Path.Combine(clientFolder, $"{nameWithoutExt}_{DateTime.Now:yyyyMMddHHmmss}{fileInfo.Extension}");
                            }
                            File.Move(dbFactura.FilePath, destinationPath);
                            dbFactura.FilePath = destinationPath;
                            dbFactura.FileName = Path.GetFileName(destinationPath);
                            dbFactura.ProcessedPath = destinationPath;
                        }
                    }
                    catch (Exception moveEx)
                    {
                        Console.WriteLine($"[ProcessWithAi] Failed to move file: {moveEx.Message}");
                    }
                }

                await context.SaveChangesAsync();

                // Auto-sync to Excel immediately
                var excelPath = settings.ScanningSettings.ExcelFilePath;
                if (string.IsNullOrWhiteSpace(excelPath))
                {
                    excelPath = Path.Combine(settings.ScanningSettings.WatchFolderPath, "FacturasSincronizadas.xlsx");
                }

                if (!string.IsNullOrWhiteSpace(excelPath))
                {
                    try
                    {
                        await ExportService.ExportToExcelIncrementalAsync(new[] { dbFactura }, excelPath);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Sincronizado en BD pero falló Excel: {ex.Message}", Severity.Warning);
                    }
                }

                Snackbar.Add($"Factura '{factura.FileName}' procesada e inyectada con éxito.", Severity.Success);
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al procesar con IA: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingAiIds.Remove(factura.Id);
            StateHasChanged();
        }
    }

