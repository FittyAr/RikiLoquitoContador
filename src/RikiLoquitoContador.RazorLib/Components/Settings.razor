@using Microsoft.EntityFrameworkCore
@using RikiLoquitoContador.Core.Data
@using RikiLoquitoContador.Core.Models
@inject IConfigService ConfigService
@inject IFileScannerService FileScanner
@inject IAiService AiService
@inject II18nService Localizer
@inject ISnackbar Snackbar
@inject IDbContextFactory<AppDbContext> DbContextFactory

<style>
    /* Styling for the MudTabs vertical container */
    .settings-tabs.mud-tabs-vertical {
        min-height: 480px !important;
    }
    
    .settings-tabs .mud-tabs-tabbar-vertical {
        background: rgba(0, 0, 0, 0.2) !important;
        border-right: 1px solid rgba(255, 255, 255, 0.08) !important;
        min-width: 240px !important;
        width: 240px !important;
        padding: 16px 8px !important;
    }

    .settings-tabs .mud-tabs-panels {
        flex-grow: 1 !important;
        padding-left: 12px !important;
    }

    /* Style for each individual tab button */
    .settings-tabs .mud-tab {
        justify-content: flex-start !important;
        text-align: left !important;
        padding: 12px 16px !important;
        margin: 6px 8px !important;
        border-radius: 8px !important;
        color: rgba(255, 255, 255, 0.7) !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        text-transform: none !important; /* Avoid all-caps */
        font-weight: 500 !important;
        font-size: 0.92rem !important;
        letter-spacing: 0.2px !important;
    }

    /* Icon spacing and coloring inside tab */
    .settings-tabs .mud-tab .mud-tab-icon {
        margin-right: 12px !important;
        margin-bottom: 0 !important; /* Reset vertical centering for text alignment */
        color: rgba(255, 255, 255, 0.5) !important;
        transition: color 0.25s ease !important;
    }

    /* Hover state */
    .settings-tabs .mud-tab:hover {
        background: rgba(194, 254, 113, 0.05) !important;
        color: #C2FE71 !important;
    }
    
    .settings-tabs .mud-tab:hover .mud-tab-icon {
        color: #C2FE71 !important;
    }

    /* Active state styling */
    .settings-tabs .mud-tab-active {
        background: rgba(194, 254, 113, 0.12) !important;
        color: #C2FE71 !important;
        font-weight: 600 !important;
    }
    
    .settings-tabs .mud-tab-active .mud-tab-icon {
        color: #C2FE71 !important;
    }

    /* Hide the default slider underbar */
    .settings-tabs .mud-tab-slider {
        display: none !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <MudCard Elevation="8" Class="rounded-lg" Style="background: rgba(33, 33, 33, 0.85); color: white; border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Success" Class="mr-3" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; color: #C2FE71;">
                        @Localizer.T("Settings.Title")
                    </MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudTabs Position="Position.Left" 
                         KeepPanelsAlive="true" 
                         Color="Color.Transparent" 
                         IconColor="Color.Success" 
                         SliderColor="Color.Success"
                         Class="rounded-lg settings-tabs" 
                         Style="background: transparent;">
                    
                    <!-- PESTAÑA 1: MONITOREO Y EXCEL -->
                    <MudTabPanel Text="Monitoreo y Excel" Icon="@Icons.Material.Filled.Folder">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        Monitoreo de Archivos
                                    </MudText>
                                </div>

                                <MudGrid>
                                    <!-- Entrada -->
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_watchFolderPath"
                                                      Label="@Localizer.T("Settings.FolderPath")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador\Entrada"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Folder" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_directoryExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Existe</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">No existe</MudChip>
                                        }
                                    </MudItem>

                                    <!-- Procesadas -->
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_processedFolderPath"
                                                      Label="@Localizer.T("Settings.ProcessedFolderPath")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador\Procesadas"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.FolderSpecial" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_processedDirExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Existe</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">No existe</MudChip>
                                        }
                                    </MudItem>

                                    <!-- Conflictos -->
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_conflictsFolderPath"
                                                      Label="@Localizer.T("Settings.ConflictsFolderPath")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador\Conflictos"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.ReportGmailerrorred" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_conflictsDirExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Existe</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">No existe</MudChip>
                                        }
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            Rutas absolutas del sistema para Entrada, Procesadas (por carpeta de cliente) y Conflictos (archivos fallidos).
                                        </MudText>
                                    </MudItem>

                                    <!-- Clientes Contador List Editor -->
                                    <MudItem xs="12" Class="mt-2">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600; color: #C2FE71;" Class="mb-2">
                                            Clientes del Contador
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-4">
                                            Configura los CUITs de los clientes del contador junto con su descripción/nombre. Esto servirá para clasificar automáticamente las facturas procesadas en carpetas de Emitidas (Ventas) o Recibidas (Compras) bajo su respectivo nombre.
                                        </MudText>
                                        
                                        <div class="d-flex gap-3 mb-4 align-center">
                                            <MudTextField @bind-Value="_newClientCuit" 
                                                          Label="CUIT del Cliente" 
                                                          Placeholder="30765432109" 
                                                          Margin="Margin.Dense" 
                                                          Variant="Variant.Outlined" 
                                                          Style="color: white; max-width: 180px;" />
                                            <MudTextField @bind-Value="_newClientName" 
                                                          Label="Nombre / Descripción" 
                                                          Placeholder="Juan Perez SRL" 
                                                          Margin="Margin.Dense" 
                                                          Variant="Variant.Outlined" 
                                                          Style="color: white; flex-grow: 1;" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                                           Color="Color.Success" 
                                                           OnClick="AddContadorClient" 
                                                           Size="Size.Medium" 
                                                           Style="margin-top: 4px;" />
                                        </div>

                                        <MudTable Items="_clientesContador" 
                                                  Dense="true" 
                                                  Hover="true" 
                                                  Height="250px" 
                                                  FixedHeader="true"
                                                  Elevation="0"
                                                  Style="background: rgba(43, 43, 43, 0.4); color: white;"
                                                  Class="rounded-lg">
                                            <HeaderContent>
                                                <MudTh Style="color: #C2FE71; font-weight: 600; width: 180px;">CUIT</MudTh>
                                                <MudTh Style="color: #C2FE71; font-weight: 600;">Nombre / Descripción</MudTh>
                                                <MudTh Style="color: #C2FE71; font-weight: 600; text-align: center; width: 80px;">Acciones</MudTh>
                                            </HeaderContent>
                                            <RowTemplate Context="clientContext">
                                                <MudTd>@clientContext.Cuit</MudTd>
                                                <MudTd>@clientContext.Nombre</MudTd>
                                                <MudTd Style="text-align: center;">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                                   Color="Color.Error" 
                                                                   Size="Size.Small" 
                                                                   OnClick="@(() => DeleteContadorClient(clientContext))" />
                                                </MudTd>
                                            </RowTemplate>
                                            <NoRecordsContent>
                                                <div class="pa-4 text-center">
                                                    <MudText Class="mud-text-secondary italic">No se han configurado clientes del contador.</MudText>
                                                </div>
                                            </NoRecordsContent>
                                        </MudTable>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudNumericField @bind-Value="_scanInterval"
                                                         Label="Intervalo de Escaneo (Segundos)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Style="color: white;"
                                                         Min="5"
                                                         Max="3600" />
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="d-flex align-center">
                                        <MudSwitch T="bool" @bind-Value="_treatPdfAsImage"
                                                   Label="Tratar PDFs como imágenes (Experimental)"
                                                   Color="Color.Success"
                                                   Style="color: white;" />
                                    </MudItem>
                                </MudGrid>
                            </div>

                            <MudDivider Style="background-color: rgba(255, 255, 255, 0.1);" />

                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.GridOn" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        Sincronización a Excel
                                    </MudText>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_excelFilePath"
                                                      Label="Ruta del Archivo de Excel (.xlsx)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador\FacturasSincronizadas.xlsx"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.FileDownload" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_excelDirExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Ruta Válida</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">Directorio Inválido</MudChip>
                                        }
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            La ruta absoluta donde se actualizará la planilla Excel de facturas.
                                        </MudText>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                    <!-- PESTAÑA 2: SEGURIDAD -->
                    <MudTabPanel Text="@Localizer.T("Settings.SecuritySection")" Icon="@Icons.Material.Filled.Lock">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        @Localizer.T("Settings.SecuritySection")
                                    </MudText>
                                </div>

                                <div class="mb-4">
                                    <MudAlert Severity="Severity.Info" 
                                              Variant="Variant.Outlined" 
                                              Class="rounded-lg border-dashed"
                                              Icon="@Icons.Material.Filled.Lock"
                                              Style="color: #A5D6A7; border-color: rgba(165, 214, 167, 0.4);">
                                        Para modificar la contraseña de acceso, debe ingresar su contraseña actual por seguridad.
                                    </MudAlert>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_currentPassword"
                                                      Label="Contraseña Actual"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_passwordInputIcon"
                                                      OnAdornmentClick="TogglePasswordVisibility"
                                                      Placeholder="Requerida solo si vas a cambiar la contraseña" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_newPassword"
                                                      Label="@Localizer.T("Settings.NewPassword")"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_passwordInputIcon"
                                                      OnAdornmentClick="TogglePasswordVisibility" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_confirmPassword"
                                                      Label="@Localizer.T("Settings.ConfirmPassword")"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Validation="@(new Func<string, string?>(ValidatePasswordMatch))" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                    <!-- PESTAÑA 3: INTELIGENCIA ARTIFICIAL -->
                    <MudTabPanel Text="@Localizer.T("Settings.AiSection")" Icon="@Icons.Material.Filled.AutoAwesome">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        @Localizer.T("Settings.AiSection")
                                    </MudText>
                                </div>

                                <div class="mb-4">
                                    <MudAlert Severity="Severity.Info" 
                                              Variant="Variant.Outlined" 
                                              Class="rounded-lg border-dashed"
                                              Icon="@Icons.Material.Filled.Help"
                                              Style="color: #A5D6A7; border-color: rgba(165, 214, 167, 0.4);">
                                        @Localizer.T("Settings.AiHelp")
                                    </MudAlert>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="string"
                                                   Label="@Localizer.T("Settings.AiProvider")"
                                                   Value="_selectedProvider"
                                                   ValueChanged="OnProviderSelected"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Style="color: white;">
                                            @foreach (var provider in _aiPresets.Keys)
                                            {
                                                <MudSelectItem Value="@provider">@provider</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <div class="d-flex align-center gap-2">
                                            @if (_ollamaModels.Any() && (_selectedProvider.Contains("Ollama") || _selectedProvider == "Personalizado"))
                                            {
                                                <MudSelect T="string"
                                                           Label="@Localizer.T("Settings.AiModel")"
                                                           @bind-Value="_aiModelName"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Style="color: white; flex-grow: 1;"
                                                           Required="true">
                                                    @foreach (var model in _ollamaModels)
                                                    {
                                                        <MudSelectItem Value="@model">@model</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                <MudTextField @bind-Value="_aiModelName"
                                                              Label="@Localizer.T("Settings.AiModel")"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Style="color: white; flex-grow: 1;"
                                                              Required="true" />
                                            }
                                            
                                            @if (_selectedProvider.Contains("Ollama") || _selectedProvider == "Personalizado")
                                            {
                                                <MudTooltip Text="Escanear y consultar modelos disponibles en Ollama">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                                   Color="Color.Info"
                                                                   OnClick="ScanOllamaModels"
                                                                   Disabled="_scanningModels"
                                                                   Size="Size.Medium"
                                                                   Style="margin-top: 4px;" />
                                                </MudTooltip>
                                            }
                                        </div>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_aiEndpoint"
                                                      Label="@Localizer.T("Settings.AiEndpoint")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_aiApiKey"
                                                      InputType="@_apiKeyInputType"
                                                      Label="@Localizer.T("Settings.AiApiKey")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_apiKeyInputIcon"
                                                      OnAdornmentClick="ToggleApiKeyVisibility" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                    <!-- PESTAÑA 4: TABLAS IMPOSITIVAS -->
                    <MudTabPanel Text="@Localizer.T("Settings.AfipSection.Title")" Icon="@Icons.Material.Filled.ReceiptLong">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <MudGrid>
                                <!-- Tipos de Comprobantes -->
                                <MudItem xs="12" md="6">
                                    <div class="d-flex align-center justify-space-between mb-3">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                            @Localizer.T("Settings.AfipSection.InvoiceTypesTab")
                                        </MudText>
                                    </div>
                                    
                                    <div class="d-flex gap-2 mb-3 align-center">
                                        <MudTextField @bind-Value="_newInvoiceCode" Label="Código" Placeholder="011" Margin="Margin.Dense" Variant="Variant.Outlined" Style="color: white; max-width: 80px;" />
                                        <MudTextField @bind-Value="_newInvoiceDesc" Label="Descripción" Placeholder="Factura C" Margin="Margin.Dense" Variant="Variant.Outlined" Style="color: white; flex-grow: 1;" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="AddInvoiceType" Size="Size.Medium" Style="margin-top: 4px;" />
                                    </div>

                                    <MudTable Items="_invoiceTypes" Dense="true" Hover="true" Height="300px" FixedHeader="true" Style="background: rgba(43, 43, 43, 0.4); color: white;">
                                        <HeaderContent>
                                            <MudTh Style="color: #C2FE71;">@Localizer.T("Settings.AfipSection.Code")</MudTh>
                                            <MudTh Style="color: #C2FE71;">@Localizer.T("Settings.AfipSection.Description")</MudTh>
                                            <MudTh Style="color: #C2FE71; text-align: center; width: 60px;">@Localizer.T("Settings.AfipSection.Actions")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.Codigo</MudTd>
                                            <MudTd title="@context.Descripcion">@context.Descripcion</MudTd>
                                            <MudTd Style="text-align: center;">
                                                @if (context.IsCustom)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteInvoiceType(context.Id))" />
                                                }
                                                else
                                                {
                                                    <span style="font-size: 0.75rem; color: rgba(255,255,255,0.3);">Fijo</span>
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudItem>

                                <!-- Categorias de IVA -->
                                <MudItem xs="12" md="6">
                                    <div class="d-flex align-center justify-space-between mb-3">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                            @Localizer.T("Settings.AfipSection.VatTypesTab")
                                        </MudText>
                                    </div>

                                    <div class="d-flex gap-2 mb-3 align-center">
                                        <MudTextField @bind-Value="_newVatDesc" Label="Descripción IVA" Placeholder="Monotributista Social" Margin="Margin.Dense" Variant="Variant.Outlined" Style="color: white; flex-grow: 1;" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="AddVatType" Size="Size.Medium" Style="margin-top: 4px;" />
                                    </div>

                                    <MudTable Items="_vatTypes" Dense="true" Hover="true" Height="300px" FixedHeader="true" Style="background: rgba(43, 43, 43, 0.4); color: white;">
                                        <HeaderContent>
                                            <MudTh Style="color: #C2FE71;">@Localizer.T("Settings.AfipSection.Description")</MudTh>
                                            <MudTh Style="color: #C2FE71; text-align: center; width: 60px;">@Localizer.T("Settings.AfipSection.Actions")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd title="@context.Descripcion">@context.Descripcion</MudTd>
                                            <MudTd Style="text-align: center;">
                                                @if (context.IsCustom)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteVatType(context.Id))" />
                                                }
                                                else
                                                {
                                                    <span style="font-size: 0.75rem; color: rgba(255,255,255,0.3);">Fijo</span>
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudTabPanel>

                </MudTabs>
            </MudForm>
        </MudCardContent>

        <MudCardActions Class="justify-end pa-6">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveSettings"
                       Disabled="!_isValid"
                       Style="background: linear-gradient(135deg, #049F6C 0%, #87D37C 100%); color: white; font-weight: 600;"
                       Class="px-6 py-2 rounded-pill">
                @Localizer.T("Settings.Save")
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private MudForm? _form;
    private bool _isValid;
    private string _watchFolderPath = string.Empty;
    private string _processedFolderPath = string.Empty;
