    protected override async Task OnInitializedAsync()
    {
        var settings = ConfigService.GetSettings();
        _watchFolderPath = settings.ScanningSettings.WatchFolderPath;
        _excelFilePath = settings.ScanningSettings.ExcelFilePath;
        _processedFolderPath = settings.ScanningSettings.ProcessedFolderPath;
        _conflictsFolderPath = settings.ScanningSettings.ConflictsFolderPath;
        _clientesContador = settings.ScanningSettings.ClientesContador?.ToList() ?? new List<ClienteContador>();
        _scanInterval = settings.ScanningSettings.ScanIntervalSeconds;
        _treatPdfAsImage = settings.ScanningSettings.TreatPdfAsImage;

        _selectedProvider = settings.AiSettings?.Provider ?? "OpenAI";
        _aiEndpoint = settings.AiSettings?.Endpoint ?? "";
        _aiModelName = settings.AiSettings?.ModelName ?? "";
        _aiApiKey = settings.AiSettings?.ApiKey ?? "";

        CheckDirectoryExists();
        await LoadTaxTablesAsync();
    }

    private async Task LoadTaxTablesAsync()
    {
        try
        {
            using var db = await DbContextFactory.CreateDbContextAsync();
            _invoiceTypes = await db.TipoFacturas.OrderBy(t => t.Codigo).ToListAsync();
            _vatTypes = await db.TipoIvas.OrderBy(t => t.Descripcion).ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando tablas impositivas: {ex.Message}", Severity.Error);
        }
    }

    private void CheckDirectoryExists()
    {
        _directoryExists = !string.IsNullOrWhiteSpace(_watchFolderPath) && System.IO.Directory.Exists(_watchFolderPath);
        _processedDirExists = !string.IsNullOrWhiteSpace(_processedFolderPath) && System.IO.Directory.Exists(_processedFolderPath);
        _conflictsDirExists = !string.IsNullOrWhiteSpace(_conflictsFolderPath) && System.IO.Directory.Exists(_conflictsFolderPath);
        
        if (!string.IsNullOrWhiteSpace(_excelFilePath))
        {
            try
            {
                var dir = System.IO.Path.GetDirectoryName(_excelFilePath);
                _excelDirExists = !string.IsNullOrWhiteSpace(dir) && System.IO.Directory.Exists(dir);
            }
            catch
            {
                _excelDirExists = false;
            }
        }
        else
        {
            _excelDirExists = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        _passwordVisibility = !_passwordVisibility;
    }

    private void ToggleApiKeyVisibility()
    {
        _apiKeyVisibility = !_apiKeyVisibility;
    }

    private string? ValidatePasswordMatch(string confirmPassword)
    {
        if (!string.IsNullOrEmpty(_newPassword) && confirmPassword != _newPassword)
        {
            return Localizer.T("Settings.PasswordMismatch");
        }
        return null;
    }

    private void OnProviderSelected(string provider)
    {
        _selectedProvider = provider;
        if (_aiPresets.TryGetValue(provider, out var preset))
        {
            if (provider != "Personalizado")
            {
                _aiEndpoint = preset.Endpoint;
                _aiModelName = preset.ModelName;
            }
        }
        _ollamaModels.Clear(); // Clear scanned models when changing provider
    }

    private async Task ScanOllamaModels()
    {
        _scanningModels = true;
        StateHasChanged();
        try
        {
            Snackbar.Add("Conectando con Ollama para escanear modelos...", Severity.Info);
            var models = await AiService.GetAvailableModelsAsync(_selectedProvider, _aiEndpoint);
            if (models != null && models.Any())
            {
                _ollamaModels = models;
                if (!_ollamaModels.Contains(_aiModelName) && _ollamaModels.Any())
                {
                    _aiModelName = _ollamaModels.First();
                }
                Snackbar.Add($"Se encontraron {models.Count} modelos locales en Ollama.", Severity.Success);
            }
            else
            {
                Snackbar.Add("No se encontraron modelos locales en Ollama. Asegúrese de que el servidor está corriendo.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al conectar con Ollama: {ex.Message}", Severity.Error);
        }
        finally
        {
            _scanningModels = false;
            StateHasChanged();
        }
    }

    private async Task SaveSettings()
    {
        if (_form == null) return;
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        try
        {
            var settings = ConfigService.GetSettings();
            
            // Stop old monitoring
            FileScanner.StopMonitoring();

            // Update scanning settings
            settings.ScanningSettings.WatchFolderPath = _watchFolderPath;
            settings.ScanningSettings.ExcelFilePath = _excelFilePath;
            settings.ScanningSettings.ProcessedFolderPath = _processedFolderPath;
            settings.ScanningSettings.ConflictsFolderPath = _conflictsFolderPath;
            settings.ScanningSettings.ClientesContador = _clientesContador;
            settings.ScanningSettings.ScanIntervalSeconds = _scanInterval;
            settings.ScanningSettings.TreatPdfAsImage = _treatPdfAsImage;

            // Update password if a new one is typed
            if (!string.IsNullOrEmpty(_newPassword))
            {
                if (string.IsNullOrEmpty(_currentPassword))
                {
                    Snackbar.Add("Debe ingresar la contraseña actual para establecer una nueva.", Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }
                
                if (!ConfigService.VerifyPassword(_currentPassword))
                {
                    Snackbar.Add("La contraseña actual es incorrecta.", Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }

                if (_newPassword != _confirmPassword)
                {
                    Snackbar.Add(Localizer.T("Settings.PasswordMismatch"), Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }
                settings.SecuritySettings.PasswordHash = ConfigService.HashPassword(_newPassword);
            }

            // Update AI settings
            if (settings.AiSettings == null)
            {
                settings.AiSettings = new AiSettings();
            }
            settings.AiSettings.Provider = _selectedProvider;
            settings.AiSettings.Endpoint = _aiEndpoint;
            settings.AiSettings.ModelName = _aiModelName;
            settings.AiSettings.ApiKey = _aiApiKey;

            ConfigService.UpdateSettings(settings);

            CheckDirectoryExists();

            // Start new monitoring
            FileScanner.StartMonitoring();

            // Clear password fields
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;

            Snackbar.Add(Localizer.T("Settings.Success"), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al guardar la configuración: {ex.Message}", Severity.Error);
        }
    }

    private async Task AddInvoiceType()
    {
        if (string.IsNullOrWhiteSpace(_newInvoiceCode) || string.IsNullOrWhiteSpace(_newInvoiceDesc))
        {
            Snackbar.Add("Debe ingresar el código y la descripción.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbContextFactory.CreateDbContextAsync();
            var exists = await db.TipoFacturas.AnyAsync(t => t.Codigo == _newInvoiceCode);
            if (exists)
            {
                Snackbar.Add("Ya existe un comprobante con ese código.", Severity.Warning);
                return;
            }

            db.TipoFacturas.Add(new TipoFactura
            {
                Codigo = _newInvoiceCode.Trim(),
                Descripcion = _newInvoiceDesc.Trim(),
                IsCustom = true
            });
            await db.SaveChangesAsync();

            _newInvoiceCode = string.Empty;
            _newInvoiceDesc = string.Empty;
            Snackbar.Add("Tipo de comprobante agregado con éxito.", Severity.Success);
            await LoadTaxTablesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al agregar: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteInvoiceType(int id)
    {
        try
        {
            using var db = await DbContextFactory.CreateDbContextAsync();
            var item = await db.TipoFacturas.FindAsync(id);
            if (item != null && item.IsCustom)
            {
                db.TipoFacturas.Remove(item);
                await db.SaveChangesAsync();
                Snackbar.Add("Comprobante eliminado.", Severity.Success);
                await LoadTaxTablesAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
    }

