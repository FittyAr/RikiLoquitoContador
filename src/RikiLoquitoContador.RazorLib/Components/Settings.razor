@inject IConfigService ConfigService
@inject IFileScannerService FileScanner
@inject II18nService Localizer
@inject ISnackbar Snackbar

<style>
    /* Styling for the MudTabs vertical container */
    .settings-tabs.mud-tabs-vertical {
        min-height: 480px !important;
    }
    
    .settings-tabs .mud-tabs-tabbar-vertical {
        background: rgba(0, 0, 0, 0.2) !important;
        border-right: 1px solid rgba(255, 255, 255, 0.08) !important;
        min-width: 240px !important;
        width: 240px !important;
        padding: 16px 8px !important;
    }

    .settings-tabs .mud-tabs-panels {
        flex-grow: 1 !important;
        padding-left: 12px !important;
    }

    /* Style for each individual tab button */
    .settings-tabs .mud-tab {
        justify-content: flex-start !important;
        text-align: left !important;
        padding: 12px 16px !important;
        margin: 6px 8px !important;
        border-radius: 8px !important;
        color: rgba(255, 255, 255, 0.7) !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        text-transform: none !important; /* Avoid all-caps */
        font-weight: 500 !important;
        font-size: 0.92rem !important;
        letter-spacing: 0.2px !important;
    }

    /* Icon spacing and coloring inside tab */
    .settings-tabs .mud-tab .mud-tab-icon {
        margin-right: 12px !important;
        margin-bottom: 0 !important; /* Reset vertical centering for text alignment */
        color: rgba(255, 255, 255, 0.5) !important;
        transition: color 0.25s ease !important;
    }

    /* Hover state */
    .settings-tabs .mud-tab:hover {
        background: rgba(194, 254, 113, 0.05) !important;
        color: #C2FE71 !important;
    }
    
    .settings-tabs .mud-tab:hover .mud-tab-icon {
        color: #C2FE71 !important;
    }

    /* Active state styling */
    .settings-tabs .mud-tab-active {
        background: rgba(194, 254, 113, 0.12) !important;
        color: #C2FE71 !important;
        font-weight: 600 !important;
    }
    
    .settings-tabs .mud-tab-active .mud-tab-icon {
        color: #C2FE71 !important;
    }

    /* Hide the default slider underbar */
    .settings-tabs .mud-tab-slider {
        display: none !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-8">
    <MudCard Elevation="8" Class="rounded-lg" Style="background: rgba(33, 33, 33, 0.85); color: white; border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Success" Class="mr-3" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; color: #C2FE71;">
                        @Localizer.T("Settings.Title")
                    </MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudTabs Position="Position.Left" 
                         KeepPanelsAlive="true" 
                         Color="Color.Transparent" 
                         IconColor="Color.Success" 
                         SliderColor="Color.Success"
                         Class="rounded-lg settings-tabs" 
                         Style="background: transparent;">
                    
                    <!-- PESTAÑA 1: MONITOREO Y EXCEL -->
                    <MudTabPanel Text="Monitoreo y Excel" Icon="@Icons.Material.Filled.Folder">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        Monitoreo de Archivos
                                    </MudText>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_watchFolderPath"
                                                      Label="@Localizer.T("Settings.FolderPath")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Folder" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_directoryExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Existe</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">No existe</MudChip>
                                        }
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            La carpeta donde el contador depositará las facturas en formato JPG, PNG, PDF o DOCX.
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudNumericField @bind-Value="_scanInterval"
                                                         Label="Intervalo de Escaneo (Segundos)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Style="color: white;"
                                                         Min="5"
                                                         Max="3600" />
                                    </MudItem>
                                </MudGrid>
                            </div>

                            <MudDivider Style="background-color: rgba(255, 255, 255, 0.1);" />

                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.GridOn" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        Sincronización a Excel
                                    </MudText>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12" md="9">
                                        <MudTextField @bind-Value="_excelFilePath"
                                                      Label="Ruta del Archivo de Excel (.xlsx)"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true"
                                                      Placeholder="C:\FacturasContador\FacturasSincronizadas.xlsx"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.FileDownload" />
                                    </MudItem>
                                    <MudItem xs="12" md="3" Class="d-flex align-center">
                                        @if (_excelDirExists)
                                        {
                                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Ruta Válida</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">Directorio Inválido</MudChip>
                                        }
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            La ruta absoluta donde se actualizará la planilla Excel de facturas.
                                        </MudText>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                    <!-- PESTAÑA 2: SEGURIDAD -->
                    <MudTabPanel Text="@Localizer.T("Settings.SecuritySection")" Icon="@Icons.Material.Filled.Lock">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        @Localizer.T("Settings.SecuritySection")
                                    </MudText>
                                </div>

                                <div class="mb-4">
                                    <MudAlert Severity="Severity.Info" 
                                              Variant="Variant.Outlined" 
                                              Class="rounded-lg border-dashed"
                                              Icon="@Icons.Material.Filled.Lock"
                                              Style="color: #A5D6A7; border-color: rgba(165, 214, 167, 0.4);">
                                        Para modificar la contraseña de acceso, debe ingresar su contraseña actual por seguridad.
                                    </MudAlert>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_currentPassword"
                                                      Label="Contraseña Actual"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_passwordInputIcon"
                                                      OnAdornmentClick="TogglePasswordVisibility"
                                                      Placeholder="Requerida solo si vas a cambiar la contraseña" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_newPassword"
                                                      Label="@Localizer.T("Settings.NewPassword")"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_passwordInputIcon"
                                                      OnAdornmentClick="TogglePasswordVisibility" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_confirmPassword"
                                                      Label="@Localizer.T("Settings.ConfirmPassword")"
                                                      InputType="@_passwordInputType"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Validation="@(new Func<string, string?>(ValidatePasswordMatch))" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                    <!-- PESTAÑA 3: INTELIGENCIA ARTIFICIAL -->
                    <MudTabPanel Text="@Localizer.T("Settings.AiSection")" Icon="@Icons.Material.Filled.AutoAwesome">
                        <div class="px-6 py-4 d-flex flex-column gap-6">
                            <div>
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Success" Class="mr-2" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: #C2FE71;">
                                        @Localizer.T("Settings.AiSection")
                                    </MudText>
                                </div>

                                <div class="mb-4">
                                    <MudAlert Severity="Severity.Info" 
                                              Variant="Variant.Outlined" 
                                              Class="rounded-lg border-dashed"
                                              Icon="@Icons.Material.Filled.Help"
                                              Style="color: #A5D6A7; border-color: rgba(165, 214, 167, 0.4);">
                                        @Localizer.T("Settings.AiHelp")
                                    </MudAlert>
                                </div>

                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="string"
                                                   Label="@Localizer.T("Settings.AiProvider")"
                                                   Value="_selectedProvider"
                                                   ValueChanged="OnProviderSelected"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Style="color: white;">
                                            @foreach (var provider in _aiPresets.Keys)
                                            {
                                                <MudSelectItem Value="@provider">@provider</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_aiModelName"
                                                      Label="@Localizer.T("Settings.AiModel")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_aiEndpoint"
                                                      Label="@Localizer.T("Settings.AiEndpoint")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Required="true" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_aiApiKey"
                                                      InputType="@_apiKeyInputType"
                                                      Label="@Localizer.T("Settings.AiApiKey")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="color: white;"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@_apiKeyInputIcon"
                                                      OnAdornmentClick="ToggleApiKeyVisibility" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudTabPanel>

                </MudTabs>
            </MudForm>
        </MudCardContent>

        <MudCardActions Class="justify-end pa-6">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveSettings"
                       Disabled="!_isValid"
                       Style="background: linear-gradient(135deg, #049F6C 0%, #87D37C 100%); color: white; font-weight: 600;"
                       Class="px-6 py-2 rounded-pill">
                @Localizer.T("Settings.Save")
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private MudForm? _form;
    private bool _isValid;
    private string _watchFolderPath = string.Empty;
    private string _excelFilePath = string.Empty;
    private int _scanInterval = 10;
    private bool _directoryExists;
    private bool _excelDirExists;

    // Security (Password)
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _passwordVisibility = false;
    private InputType _passwordInputType => _passwordVisibility ? InputType.Text : InputType.Password;
    private string _passwordInputIcon => _passwordVisibility ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    // AI Configuration
    private string _selectedProvider = "OpenAI";
    private string _aiEndpoint = string.Empty;
    private string _aiModelName = string.Empty;
    private string _aiApiKey = string.Empty;
    private bool _apiKeyVisibility = false;
    private InputType _apiKeyInputType => _apiKeyVisibility ? InputType.Text : InputType.Password;
    private string _apiKeyInputIcon => _apiKeyVisibility ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private struct AiPreset
    {
        public string Endpoint { get; set; }
        public string ModelName { get; set; }
    }

    private readonly Dictionary<string, AiPreset> _aiPresets = new()
    {
        { "OpenAI", new AiPreset { Endpoint = "https://api.openai.com/v1/chat/completions", ModelName = "gpt-4o-mini" } },
        { "Gemini", new AiPreset { Endpoint = "https://generativelanguage.googleapis.com/v1beta/openai/v1/chat/completions", ModelName = "gemini-1.5-flash" } },
        { "Kimi", new AiPreset { Endpoint = "https://api.moonshot.cn/v1/chat/completions", ModelName = "moonshot-v1-8k" } },
        { "Qwen", new AiPreset { Endpoint = "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions", ModelName = "qwen-turbo" } },
        { "Ollama (Local)", new AiPreset { Endpoint = "http://localhost:11434/v1/chat/completions", ModelName = "llama3" } },
        { "LM Studio (Local)", new AiPreset { Endpoint = "http://localhost:1234/v1/chat/completions", ModelName = "meta-llama-3-8b-instruct" } },
        { "Personalizado", new AiPreset { Endpoint = "", ModelName = "" } }
    };

    protected override void OnInitialized()
    {
        var settings = ConfigService.GetSettings();
        _watchFolderPath = settings.ScanningSettings.WatchFolderPath;
        _excelFilePath = settings.ScanningSettings.ExcelFilePath;
        _scanInterval = settings.ScanningSettings.ScanIntervalSeconds;

        _selectedProvider = settings.AiSettings?.Provider ?? "OpenAI";
        _aiEndpoint = settings.AiSettings?.Endpoint ?? "";
        _aiModelName = settings.AiSettings?.ModelName ?? "";
        _aiApiKey = settings.AiSettings?.ApiKey ?? "";

        CheckDirectoryExists();
    }

    private void CheckDirectoryExists()
    {
        _directoryExists = !string.IsNullOrWhiteSpace(_watchFolderPath) && System.IO.Directory.Exists(_watchFolderPath);
        if (!string.IsNullOrWhiteSpace(_excelFilePath))
        {
            try
            {
                var dir = System.IO.Path.GetDirectoryName(_excelFilePath);
                _excelDirExists = !string.IsNullOrWhiteSpace(dir) && System.IO.Directory.Exists(dir);
            }
            catch
            {
                _excelDirExists = false;
            }
        }
        else
        {
            _excelDirExists = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        _passwordVisibility = !_passwordVisibility;
    }

    private void ToggleApiKeyVisibility()
    {
        _apiKeyVisibility = !_apiKeyVisibility;
    }

    private string? ValidatePasswordMatch(string confirmPassword)
    {
        if (!string.IsNullOrEmpty(_newPassword) && confirmPassword != _newPassword)
        {
            return Localizer.T("Settings.PasswordMismatch");
        }
        return null;
    }

    private void OnProviderSelected(string provider)
    {
        _selectedProvider = provider;
        if (_aiPresets.TryGetValue(provider, out var preset))
        {
            if (provider != "Personalizado")
            {
                _aiEndpoint = preset.Endpoint;
                _aiModelName = preset.ModelName;
            }
        }
    }

    private async Task SaveSettings()
    {
        if (_form == null) return;
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        try
        {
            var settings = ConfigService.GetSettings();
            
            // Stop old monitoring
            FileScanner.StopMonitoring();

            // Update scanning settings
            settings.ScanningSettings.WatchFolderPath = _watchFolderPath;
            settings.ScanningSettings.ExcelFilePath = _excelFilePath;
            settings.ScanningSettings.ScanIntervalSeconds = _scanInterval;

            // Update password if a new one is typed
            if (!string.IsNullOrEmpty(_newPassword))
            {
                if (string.IsNullOrEmpty(_currentPassword))
                {
                    Snackbar.Add("Debe ingresar la contraseña actual para establecer una nueva.", Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }
                
                if (!ConfigService.VerifyPassword(_currentPassword))
                {
                    Snackbar.Add("La contraseña actual es incorrecta.", Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }

                if (_newPassword != _confirmPassword)
                {
                    Snackbar.Add(Localizer.T("Settings.PasswordMismatch"), Severity.Error);
                    FileScanner.StartMonitoring();
                    return;
                }
                settings.SecuritySettings.PasswordHash = ConfigService.HashPassword(_newPassword);
            }

            // Update AI settings
            if (settings.AiSettings == null)
            {
                settings.AiSettings = new AiSettings();
            }
            settings.AiSettings.Provider = _selectedProvider;
            settings.AiSettings.Endpoint = _aiEndpoint;
            settings.AiSettings.ModelName = _aiModelName;
            settings.AiSettings.ApiKey = _aiApiKey;

            ConfigService.UpdateSettings(settings);

            CheckDirectoryExists();

            // Start new monitoring
            FileScanner.StartMonitoring();

            // Clear password fields
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;

            Snackbar.Add(Localizer.T("Settings.Success"), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al guardar la configuración: {ex.Message}", Severity.Error);
        }
    }
}
