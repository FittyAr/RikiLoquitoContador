    private void AddContadorClient()
    {
        if (string.IsNullOrWhiteSpace(_newClientCuit) || string.IsNullOrWhiteSpace(_newClientName))
        {
            Snackbar.Add("Debe ingresar el CUIT y el Nombre/Descripción.", Severity.Warning);
            return;
        }

        var cuitClean = new string(_newClientCuit.Where(char.IsDigit).ToArray());
        if (cuitClean.Length < 10)
        {
            Snackbar.Add("CUIT inválido. Debe tener al menos 10 dígitos.", Severity.Warning);
            return;
        }

        if (_clientesContador.Any(c => new string(c.Cuit.Where(char.IsDigit).ToArray()) == cuitClean))
        {
            Snackbar.Add("Ya existe un cliente con ese CUIT.", Severity.Warning);
            return;
        }

        _clientesContador.Add(new ClienteContador
        {
            Cuit = cuitClean,
            Nombre = _newClientName.Trim()
        });

        _newClientCuit = string.Empty;
        _newClientName = string.Empty;
        Snackbar.Add("Cliente agregado temporalmente. Recuerde guardar los cambios.", Severity.Success);
    }

    private void DeleteContadorClient(ClienteContador client)
    {
        _clientesContador.Remove(client);
        Snackbar.Add("Cliente removido. Recuerde guardar los cambios.", Severity.Success);
    }
